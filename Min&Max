import java.lang.*;
class Main {
    public static void main(String[] args) {
        int arr[ ] ={7,8,5,6,2,1};
        int min=arr[0], max=arr[0];
        for(int i=1;i<arr.length;i++){
            if(arr[i]>max){
                max=arr[i];
            } if(arr[i]<min){
                min=arr[i];
            }
        }
        System.out.println("max "+ max);
       System.out.println("min "+ min);
    }
}
