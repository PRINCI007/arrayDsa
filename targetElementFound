class Main {
    public static void main(String[] args) {
        int arr[ ] ={7,8,5,6,2,1};
        int target=6; boolean found=false;
        for(int i=0;i<arr.length;i++){
            if(arr[i]==target){
                System.out.println("the target element is at "+i +" index");
                found=true;
                break;
            }
        }
        if(!found){
            System.out.println("-1");
        }
}
}
